# Deployment environment
ENV_NAME=dev
AWS_REGION=eu-west-3
ARTIFACT_BUCKET=studiinfra-cfn-artifacts-bucket
CFN_EXEC_ROLE_ARN=arn:aws:iam::142706263687:role/cfn-studistoreinfra-exec-role

# Network parameters
VPC_CIDR=10.0.0.0/16
PUBLIC_SUBNET_A_CIDR=10.0.0.0/24
PUBLIC_SUBNET_B_CIDR=10.0.1.0/24
PRIVATE_SUBNET_A_CIDR=10.0.10.0/24
PRIVATE_SUBNET_B_CIDR=10.0.11.0/24
